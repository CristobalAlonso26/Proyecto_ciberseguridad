# ============================================================
# Security Vulnerability Analysis Pipeline — Variables de Entorno
# ============================================================
# Copiar este archivo a .env y completar los valores requeridos:
#   cp .env.example .env
# ============================================================

# ----------------------------------------------------------
# GitHub (requerido para el Miner)
# ----------------------------------------------------------
# Token de acceso personal con permisos: public_repo, read:org
# Generar en: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_token_here

# Nombre de la organizacion a analizar (ej: microsoft, google)
GITHUB_ORG=your-org-name

# ----------------------------------------------------------
# Configuracion del Miner
# ----------------------------------------------------------
# Maximo de repositorios a analizar (default: 50)
REPO_LIMIT=50

# Visibilidad de repos: all, public, private, internal
REPO_VISIBILITY=public

# Ignorar repositorios archivados
SKIP_ARCHIVED=true

# Profundidad del clone: none=completo, 1=ultimo commit
CLONE_DEPTH=none

# Workers para clonado en paralelo
CLONE_WORKERS=3

# ----------------------------------------------------------
# Rutas de datos (default: dentro del contenedor)
# ----------------------------------------------------------
# DATA_ROOT=/data
# REPOS_ROOT=/data/repos
# RESULTS_ROOT=/data/results
# REPORTS_ROOT=/data/reports
